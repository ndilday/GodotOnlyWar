; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="OnlyWarGodot"
run/main_scene="uid://b5sny34jdvj4p"
config/features=PackedStringArray("4.7", "C#", "GL Compatibility")
config/icon="res://Assets/onlywar_windows_icon.png"
config/windows_native_icon="res://Assets/onlywar_windows_icon.ico"
run/low_processor_mode=true
run/max_fps=60

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/size/resizable=false
window/vsync/vsync_mode=1

[dotnet]

project/assembly_name="OnlyWarGodot"

[rendering]

renderer/rendering_method="gl_compatibility"
